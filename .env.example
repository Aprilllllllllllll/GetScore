# ============================================
# GetScore 配置文件模板
# 使用方法: 复制为 .env 并填入真实信息
#   cp .env.example .env
# ============================================

# ---- CAS 登录信息（必填） ----
# 请填入你的真实学号和密码（保持未填时为空，便于程序检测未配置状态）
STUDENT_ID=
PASSWORD=

# ---- 通知配置（可选，不配则仅控制台输出） ----
# Server酱 Turbo SendKey，获取地址: https://sct.ftqq.com/
SERVER_CHAN_KEY=

# ---- 轮询配置（可选） ----
# 定时轮询间隔，单位：分钟，默认 30
POLL_INTERVAL_MINUTES=30

# ---- 高级配置（可选，通常无需修改） ----
# 教务系统 RSA 公钥若失效，可在此覆盖（需重新抓包获取）
# RSA_PUBLIC_KEY=
